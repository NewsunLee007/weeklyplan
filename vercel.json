{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install && cd frontend && npm install && cd ../vercel-api && npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/vercel-api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "vercel-api/index.js": {
      "maxDuration": 60
    }
  },
  "env": {
    "NODE_VERSION": "18"
  }
}
